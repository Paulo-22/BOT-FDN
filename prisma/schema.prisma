// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            Int      @id @default(autoincrement())
  discord_id    String   @unique
  discord_nome  String
  nome_mta      String
  login         String
  id_gamer      String   @unique
  telefone      String?
  cargo         String   @default("Sem Cargo")
  data_registro DateTime @default(now())

  horas                 Hora[]
  ausencias             Ausencia[]
  advertencias          Advertencia[]     @relation("UsuarioAdvertido")
  advertenciasAplicadas Advertencia[]     @relation("ResponsavelAdvertencia")
  promocoes             Promocao[]        @relation("UsuarioPromovido")
  promocoesFeitas       Promocao[]        @relation("ResponsavelPromocao")
  rebaixamentos         Rebaixamento[]    @relation("UsuarioRebaixado")
  rebaixamentosFeitos   Rebaixamento[]    @relation("ResponsavelRebaixamento")
  exoneracoes           Exoneracao[]      @relation("UsuarioExonerado")
  exoneracoesFeitas     Exoneracao[]      @relation("ResponsavelExoneracao")
  punicoes              Punicao[]         @relation("UsuarioPunido")
  punicoesAplicadas     Punicao[]         @relation("ResponsavelPunicao")
  transferencias        Transferencia[]   @relation("UsuarioTransferido")
  rankingSnapshots      RankingSnapshot[]
  metasAtingidas        MetaAtingida[]

  @@map("usuarios")
}

model Hora {
  id          Int       @id @default(autoincrement())
  usuario     String
  inicio      DateTime
  fim         DateTime?
  tempo_total Int?
  canal       String?
  ativo       Boolean   @default(true)

  user Usuario @relation(fields: [usuario], references: [discord_id])

  @@map("horas")
}

model Ausencia {
  id          Int      @id @default(autoincrement())
  usuario     String
  motivo      String
  data_inicio String
  data_fim    String
  status      String   @default("PENDENTE")
  responsavel String?
  criado_em   DateTime @default(now())

  user Usuario @relation(fields: [usuario], references: [discord_id])

  @@map("ausencias")
}

model Advertencia {
  id          Int      @id @default(autoincrement())
  usuario     String
  responsavel String
  motivo      String
  data        DateTime @default(now())

  user Usuario @relation("UsuarioAdvertido",       fields: [usuario],     references: [discord_id])
  resp Usuario @relation("ResponsavelAdvertencia", fields: [responsavel], references: [discord_id])

  @@map("advertencias")
}

model Punicao {
  id            Int       @id @default(autoincrement())
  usuario       String
  responsavel   String
  tipo          String    // PUNICAO_1, PUNICAO_2, PUNICAO_3, REMOCAO
  motivo        String
  data          DateTime  @default(now())

  // Expiração automática (não se aplica a REMOCAO, que é permanente)
  duracao_dias  Int?      // null = sem expiração / permanente
  expira_em     DateTime? // null = sem expiração / permanente
  status        String    @default("ATIVA") // ATIVA, EXPIRADA, REMOVIDA_MANUAL
  removida_em   DateTime?
  removido_por  String?   // discord_id de quem removeu manualmente (null se expirou automaticamente)

  user Usuario @relation("UsuarioPunido",      fields: [usuario],     references: [discord_id])
  resp Usuario @relation("ResponsavelPunicao", fields: [responsavel], references: [discord_id])

  @@map("punicoes")
}

model Promocao {
  id           Int      @id @default(autoincrement())
  usuario      String
  cargo_antigo String
  cargo_novo   String
  motivo       String
  responsavel  String
  data         DateTime @default(now())

  user Usuario @relation("UsuarioPromovido",    fields: [usuario],     references: [discord_id])
  resp Usuario @relation("ResponsavelPromocao", fields: [responsavel], references: [discord_id])

  @@map("promocoes")
}

model Rebaixamento {
  id           Int      @id @default(autoincrement())
  usuario      String
  cargo_antigo String
  cargo_novo   String
  motivo       String
  responsavel  String
  data         DateTime @default(now())

  user Usuario @relation("UsuarioRebaixado",        fields: [usuario],     references: [discord_id])
  resp Usuario @relation("ResponsavelRebaixamento", fields: [responsavel], references: [discord_id])

  @@map("rebaixamentos")
}

model Exoneracao {
  id          Int      @id @default(autoincrement())
  usuario     String
  motivo      String
  responsavel String
  data        DateTime @default(now())

  user Usuario @relation("UsuarioExonerado",      fields: [usuario],     references: [discord_id])
  resp Usuario @relation("ResponsavelExoneracao", fields: [responsavel], references: [discord_id])

  @@map("exoneracoes")
}

// ─────────────────────────────────────────────────────────────────
// ALTERAÇÃO NO MODEL Transferencia — apenas o campo novo foi adicionado
// ─────────────────────────────────────────────────────────────────

model Transferencia {
  id           Int      @id @default(autoincrement())
  usuario      String
  id_gamer     String   // NOVO — ID na cidade informado na solicitação
  faccao_atual String
  cargo_antigo String   // NOVO — cargo que o membro tinha na facção de origem
  motivo       String
  status       String   @default("PENDENTE")
  responsavel  String?
  criado_em    DateTime @default(now())

  user Usuario @relation("UsuarioTransferido", fields: [usuario], references: [discord_id])

  @@map("transferencias")
}



model Candidatura {
  id           Int      @id @default(autoincrement())
  discord_id   String
  discord_nome String
  nome         String
  id_gamer     String
  horas        String
  experiencia  String
  motivo       String
  status       String   @default("PENDENTE")
  responsavel  String?
  criado_em    DateTime @default(now())

  @@map("candidaturas")
}

model Edital {
  id           Int       @id @default(autoincrement())
  discord_id   String
  discord_nome String
  nick         String
  canal_id     String    @unique
  respostas    Json
  status       String    @default("PENDENTE")
  responsavel  String?
  criado_em    DateTime  @default(now())
  analisado_em DateTime?

  @@map("editais")
}

model Ticket {
  id         Int       @id @default(autoincrement())
  canal_id   String    @unique
  autor_id   String
  tipo       String
  status     String    @default("ABERTO")
  transcript String?
  criado_em  DateTime  @default(now())
  fechado_em DateTime?

  @@map("tickets")
}

// ─────────────────────────────────────────────────────────────────────────────
// SISTEMA DE RANKING — models adicionados para o rankingService.js / scheduler.js
// ─────────────────────────────────────────────────────────────────────────────

model RankingSnapshot {
  id        Int      @id @default(autoincrement())
  usuario   String
  mes       DateTime
  total     Int
  criado_em DateTime @default(now())

  user Usuario @relation(fields: [usuario], references: [discord_id])

  @@unique([usuario, mes], name: "usuario_mes")
  @@map("ranking_snapshots")
}

// Garante que a notificação de "meta batida" só dispare uma vez por usuário/mês
model MetaAtingida {
  id            Int      @id @default(autoincrement())
  usuario       String
  mes           DateTime
  notificado_em DateTime @default(now())

  user Usuario @relation(fields: [usuario], references: [discord_id])

  @@unique([usuario, mes], name: "usuario_mes_meta")
  @@map("metas_atingidas")
}

// Tabela genérica de chave/valor para estado que precisa sobreviver a restarts do bot
// (usada hoje pelo scheduler para lembrar o último mês em que o reset mensal rodou)
model EstadoSistema {
  chave         String   @id
  valor_texto   String?
  atualizado_em DateTime @updatedAt

  @@map("estado_sistema")
}